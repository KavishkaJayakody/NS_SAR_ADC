// VerilogA for FYP_22, analog_mux, veriloga

`include "constants.vams"
`include "disciplines.vams"

module analog_mux(OUT, VDD, VSS, CTRL, IN0, IN1);
output OUT;
electrical OUT;
inout VDD;
electrical VDD;
inout VSS;
electrical VSS;
input CTRL;
electrical CTRL;
input IN0;
electrical IN0;
input IN1;
electrical IN1;


endmodule
